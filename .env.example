# -----------------------------------------------------------------------------
# Guide: generate secure values
# -----------------------------------------------------------------------------
# PowerShell:
#   [Convert]::ToBase64String((1..48 | % { Get-Random -Max 256 }))  # master
#   [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 }))  # internal
#
# OpenSSL:
#   openssl rand -base64 48  # master
#   openssl rand -base64 32  # internal
# -----------------------------------------------------------------------------

# Image tag to deploy from GHCR.
# Use a stable tag like v0.1.1, or "next" for preview builds.
NEXIS_IMAGE_TAG=v0.1.1

# Shared secrets between control-api and rust-server.
# Change these values before deploying.
NEXIS_MASTER_SECRET=change-me-super-secret
NEXIS_INTERNAL_TOKEN=change-me-internal-token

# Data-plane auth mode: required | optional | disabled
NEXIS_AUTH_MODE=required

# Session resume TTL in seconds
NEXIS_SESSION_TTL_SECONDS=30

# Optional JSON map for template room plugins
# Example: {"duel_room":{"hp":100},"lobby_room":{"players":[]}}
NEXIS_ROOM_TYPE_PLUGINS=

# Optional JSON map for WASM room plugins inside the container
# Example: {"counter_plugin_room":"/app/plugins/nexis_counter_plugin.wasm"}
NEXIS_WASM_ROOM_PLUGINS=
